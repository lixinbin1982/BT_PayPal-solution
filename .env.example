# PayPal sandbox REST app credentials
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-paypal-sandbox-secret

# Braintree sandbox gateway credentials
BT_MERCHANT_ID=your-braintree-merchant-id
BT_PUBLIC_KEY=your-braintree-public-key
BT_PRIVATE_KEY=your-braintree-private-key

# Public URL of the deployed site (required for PayPal App Switch
# return/cancel URLs). Leave empty for local dev.
BASE_URL=

PORT=3000
